# Optional fallback access token. You can now add/select tokens in the
# dashboard (stored encrypted in Redis); this .env value is only the default
# "Token mặc định (.env)" option. Leave blank to manage tokens entirely in UI.
FACEBOOK_ACCESS_TOKEN=
# Optional default ad account. The dashboard lists every ad account the active
# token can reach and lets you pick one; this is only the pre-selected fallback.
FACEBOOK_AD_ACCOUNT_ID=
FACEBOOK_API_VERSION=v23.0

# REQUIRED to add tokens via the dashboard. Master key used to encrypt stored
# access tokens at rest (AES-256-GCM). Generate with: openssl rand -base64 32
# Changing this value invalidates all previously stored tokens (re-add them).
TOKEN_ENCRYPTION_KEY=

REDIS_URL=redis://localhost:6379

R2_ACCOUNT_ID=
R2_BUCKET=
R2_REGION=auto
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
# R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com

UPLOAD_JOB_QUEUE_NAME=audience-upload-sync
UPLOAD_JOB_S3_PREFIX=audience-uploads
UPLOAD_JOB_TTL_SECONDS=86400
UPLOAD_PRESIGN_TTL_SECONDS=900
UPLOAD_JOB_ATTEMPTS=168
UPLOAD_WORKER_CONCURRENCY=1
UPLOAD_WORKER_RATE_LIMIT_MAX=1
UPLOAD_WORKER_RATE_LIMIT_DURATION_MS=1000
# Hashes per Meta request (Meta documents 10000/call; raise to test, lower if rejected)
UPLOAD_META_BATCH_SIZE=10000
# Throughput ceiling in hashes/second; request spacing is derived from this
UPLOAD_META_MAX_PER_SEC=10000
# Optional legacy override for request spacing; leave unset to derive from the rate above
# UPLOAD_META_REQUEST_INTERVAL_MS=1000
UPLOAD_META_RATE_LIMIT_DELAY_MS=3600000

WEBDAV_BASE_URL=https://nas-api.batmedia.info/
WEBDAV_USERNAME=
WEBDAV_PASSWORD=
